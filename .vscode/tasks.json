{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build with GNU g++",
      "type": "shell",
      "command": "g++-15",
      "args": [
        "-std=gnu++17",
        "-O2",
        "-Wall",
        "${file}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}